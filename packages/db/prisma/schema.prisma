generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdFamilies Family[]
  familyMembers   FamilyMember[]
  personNode      PersonNode?
}

model Family {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  avatarBase64        String?
  isActive            Boolean   @default(true)
  deletionRequestedAt DateTime?
  createdAt           DateTime  @default(now())

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  members     FamilyMember[]
  invitations FamilyInvitation[]
}

model FamilyMember {
  id       String       @id @default(uuid())
  role     FamilyRole
  status   MemberStatus @default(PENDING)
  joinedAt DateTime     @default(now())

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  personNode   PersonNode @relation(fields: [personNodeId], references: [id])
  personNodeId String

  sentInvitations FamilyInvitation[]

  @@unique([userId, familyId])
}

enum FamilyRole {
  PARENT
  CHILD
  GUARDIAN
  SENIOR
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LEFT
  REMOVED
}

model PersonNode {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  birthDate    DateTime?
  avatarBase64 String?
  createdAt    DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  familyMembers FamilyMember[]
}

model FamilyInvitation {
  id         String     @id @default(uuid())
  token      String     @unique
  email      String
  role       FamilyRole
  expiresAt  DateTime
  usedAt     DateTime?
  declinedAt DateTime?
  createdAt  DateTime   @default(now())

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  invitedBy   FamilyMember @relation(fields: [invitedById], references: [id])
  invitedById String
}
