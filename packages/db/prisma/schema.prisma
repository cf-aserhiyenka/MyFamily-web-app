generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdFamilies Family[]
  familyMembers   FamilyMember[]
  personNode      PersonNode?
}

model Family {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  avatarBase64        String?
  isActive            Boolean   @default(true)
  deletionRequestedAt DateTime?
  createdAt           DateTime  @default(now())

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  members       FamilyMember[]
  invitations   FamilyInvitation[]
  conversations Conversation[]
  budgets       Budget[]
  expenses      Expense[]
  savingGoals   SavingGoal[]
}

model FamilyMember {
  id       String       @id @default(uuid())
  role     FamilyRole
  status   MemberStatus @default(PENDING)
  joinedAt DateTime     @default(now())

  user     User   @relation(fields: [userId], references: [id])
  userId   String
  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  personNode   PersonNode @relation(fields: [personNodeId], references: [id])
  personNodeId String

  sentInvitations          FamilyInvitation[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                  @relation("MessageSender")
  createdConversations     Conversation[]             @relation("ConversationCreatedBy")
  createdBudgets           Budget[]                   @relation("BudgetCreatedBy")
  paidExpenses             Expense[]                  @relation("ExpensePaidBy")
  createdSavingGoals       SavingGoal[]               @relation("SavingGoalCreatedBy")
  goalContributions        GoalContribution[]         @relation("GoalContributionMember")

  @@unique([userId, familyId])
}

enum FamilyRole {
  PARENT
  CHILD
  GUARDIAN
  SENIOR
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LEFT
  REMOVED
}

model PersonNode {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  birthDate    DateTime?
  avatarBase64 String?
  createdAt    DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  familyMembers FamilyMember[]
}

model FamilyInvitation {
  id         String     @id @default(uuid())
  token      String     @unique
  email      String
  role       FamilyRole
  expiresAt  DateTime
  usedAt     DateTime?
  declinedAt DateTime?
  createdAt  DateTime   @default(now())

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  invitedBy   FamilyMember @relation(fields: [invitedById], references: [id])
  invitedById String
}


enum ConversationType {
  GROUP_DEFAULT
  GROUP_CUSTOM
  DIRECT
}

model Conversation {
  id            String           @id @default(uuid())
  type          ConversationType
  name          String?
  createdAt     DateTime         @default(now())
  lastMessageAt DateTime?

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  createdBy   FamilyMember? @relation("ConversationCreatedBy", fields: [createdById], references: [id])
  createdById String?

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id       String    @id @default(uuid())
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  member   FamilyMember @relation(fields: [memberId], references: [id])
  memberId String

  @@unique([conversationId, memberId])
}

model Message {
  id        String    @id @default(uuid())
  content   String
  sentAt    DateTime  @default(now())
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   FamilyMember @relation("MessageSender", fields: [senderId], references: [id])
  senderId String
}

enum BudgetCategory {
  GROCERIES
  BILLS
  EDUCATION
  HEALTH
  ENTERTAINMENT
  TRANSPORT
  OTHER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id          String         @id @default(uuid())
  name        String
  category    BudgetCategory
  limitAmount Decimal        @db.Decimal(12, 2)
  period      BudgetPeriod
  currency    String         @default("PLN")
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  createdBy   FamilyMember @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  createdById String

  expenses Expense[]
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  budget   Budget? @relation(fields: [budgetId], references: [id])
  budgetId String?

  paidBy   FamilyMember @relation("ExpensePaidBy", fields: [paidById], references: [id])
  paidById String
}

model SavingGoal {
  id           String    @id @default(uuid())
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  deadline     DateTime?
  currency     String    @default("PLN")
  isAchieved   Boolean   @default(false)
  createdAt    DateTime  @default(now())

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  createdBy   FamilyMember @relation("SavingGoalCreatedBy", fields: [createdById], references: [id])
  createdById String

  contributions GoalContribution[]
}

model GoalContribution {
  id            String   @id @default(uuid())
  amount        Decimal  @db.Decimal(12, 2)
  note          String?
  contributedAt DateTime @default(now())

  goal   SavingGoal @relation(fields: [goalId], references: [id])
  goalId String

  member   FamilyMember @relation("GoalContributionMember", fields: [memberId], references: [id])
  memberId String
}